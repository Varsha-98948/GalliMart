<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Profile Image -->
        <ImageView
            android:id="@+id/ivProfileShopkeeper"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/ic_profile_placeholder"
            android:background="@drawable/profile_placeholder_bg"
            android:padding="12dp"
            android:contentDescription="Profile Image"
            android:layout_marginBottom="16dp"
            app:tint="#202A44"/>

        <!-- Name -->
        <TextView
            android:id="@+id/tvNameShopkeeper"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Shopkeeper Name"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#202A44"
            android:layout_marginBottom="4dp"/>

        <!-- Email -->
        <TextView
            android:id="@+id/tvEmailShopkeeper"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="email@example.com"
            android:textSize="14sp"
            android:textColor="#202A44"
            android:layout_marginBottom="4dp"/>

        <!-- Role -->
        <TextView
            android:id="@+id/tvRoleShopkeeper"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Shopkeeper"
            android:textSize="14sp"
            android:textColor="#888888"
            android:layout_marginBottom="24dp"/>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="24dp"/>

        <!-- Map View for Shop Location -->
        <org.osmdroid.views.MapView
            android:id="@+id/mapShopLocation"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginBottom="24dp"/>

        <!-- Option: My Orders -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/optionOrdersShopkeeper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_cart"
                    android:contentDescription="Orders"
                    app:tint="#202A44"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="My Orders"
                    android:textSize="16sp"
                    android:textColor="#202A44"
                    android:layout_marginStart="16dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Option: View Shop Location -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/optionSaveLocationShopkeeper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_home"
                    android:contentDescription="Shop Location"
                    app:tint="#202A44"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Shop Location"
                    android:textSize="16sp"
                    android:textColor="#202A44"
                    android:layout_marginStart="16dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Option: Help -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/optionHelpShopkeeper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_help"
                    android:contentDescription="Help"
                    app:tint="#202A44"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Help"
                    android:textSize="16sp"
                    android:textColor="#202A44"
                    android:layout_marginStart="16dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Logout Button -->
        <Button
            android:id="@+id/btnLogoutShopkeeper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Logout"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/red"
            android:padding="12dp"
            android:elevation="4dp"
            android:layout_marginTop="8dp"/>

    </LinearLayout>
</ScrollView>
