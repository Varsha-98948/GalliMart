<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Order Info -->
        <TextView
            android:id="@+id/tvOrderId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Order #1234"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@color/dark_navy"/>

        <TextView
            android:id="@+id/tvOrderStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status: Pending"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            android:textColor="@color/dark_navy"/>

        <TextView
            android:id="@+id/tvOrderRoute"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pickup → Delivery"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            android:textColor="@color/dark_navy"/>

        <!-- Buttons Row -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:weightSum="2">

            <Button
                android:id="@+id/btnAcceptOrder"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Accept"
                android:textColor="@color/white"
                android:backgroundTint="@color/red"
                android:padding="12dp"
                android:layout_marginEnd="6dp"
                android:stateListAnimator="@null"/>

            <Button
                android:id="@+id/btnRejectOrder"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Reject"
                android:textColor="@color/white"
                android:backgroundTint="@color/red"
                android:padding="12dp"
                android:layout_marginStart="6dp"
                android:stateListAnimator="@null"/>
        </LinearLayout>

        <!-- Delivery Buttons Row -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:weightSum="2">

            <Button
                android:id="@+id/btnUploadPhoto"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Upload Photo"
                android:textColor="@color/white"
                android:backgroundTint="@color/red"
                android:padding="12dp"
                android:layout_marginEnd="6dp"
                android:stateListAnimator="@null"/>

            <Button
                android:id="@+id/btnMarkDelivered"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Mark Delivered"
                android:textColor="@color/white"
                android:backgroundTint="@color/red"
                android:padding="12dp"
                android:layout_marginStart="6dp"
                android:stateListAnimator="@null"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
