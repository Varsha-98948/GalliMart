<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:padding="16dp"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?android:attr/selectableItemBackground">

    <TextView android:id="@+id/tvOrderId" android:textSize="16sp" android:textStyle="bold"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

    <TextView android:id="@+id/tvOrderStatus" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <TextView android:id="@+id/tvOrderRoute" android:layout_width="wrap_content" android:layout_height="wrap_content"/>

    <Button android:id="@+id/btnConfirmDelivery" android:text="Confirm Delivery"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
</LinearLayout>
