<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="8dp"
    android:layout_marginHorizontal="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp"
    android:foreground="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Pickup -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_home"
                app:tint="@color/dark_navy" />

            <TextView
                android:id="@+id/tvPickup"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Pickup Location"
                android:textColor="@color/dark_navy"
                android:textSize="16sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Delivery -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_home"
                app:tint="@color/red" />

            <TextView
                android:id="@+id/tvDelivery"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Delivery Location"
                android:textColor="@color/colorOnSurfaceVariant"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- Distance -->
        <TextView
            android:id="@+id/tvDistance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Approx: 0.00 km"
            android:textSize="13sp"
            android:textColor="@color/colorOnSurfaceVariant"
            android:layout_marginTop="6dp"
            android:visibility="gone"/>

        <!-- Buttons Row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="12dp"
            android:weightSum="2">

            <Button
                android:id="@+id/btnAccept"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Accept"
                android:visibility="gone"
                android:backgroundTint="@color/colorPrimary"
                android:textColor="@color/white"
                android:layout_marginEnd="8dp"
                android:paddingVertical="10dp"
                android:background="@drawable/rounded_button"/>

            <Button
                android:id="@+id/btnReject"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Reject"
                android:visibility="gone"
                android:backgroundTint="@color/red"
                android:textColor="@color/white"
                android:paddingVertical="10dp"
                android:background="@drawable/rounded_button"/>
        </LinearLayout>

        <!-- Buttons Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:weightSum="2">

            <Button
                android:id="@+id/btnUploadPhotoItem"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Upload Photo"
                android:visibility="gone"
                android:backgroundTint="@color/dark_navy"
                android:textColor="@color/white"
                android:layout_marginEnd="8dp"
                android:paddingVertical="10dp"
                android:background="@drawable/rounded_button"/>

            <Button
                android:id="@+id/btnMarkDeliveredItem"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Mark Delivered"
                android:visibility="gone"
                android:backgroundTint="@color/dark_navy"
                android:textColor="@color/white"
                android:paddingVertical="10dp"
                android:background="@drawable/rounded_button"/>
        </LinearLayout>

        <!-- Buttons Row 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:weightSum="2">

            <Button
                android:id="@+id/btnDirectionsItem"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Directions"
                android:visibility="gone"
                android:backgroundTint="@color/colorPrimary"
                android:textColor="@color/white"
                android:layout_marginEnd="8dp"
                android:paddingVertical="10dp"
                android:background="@drawable/rounded_button"/>

            <Button
                android:id="@+id/btnShowRouteItem"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Show on Map"
                android:visibility="gone"
                android:backgroundTint="@color/teal_700"
                android:textColor="@color/white"
                android:paddingVertical="10dp"
                android:background="@drawable/rounded_button"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>